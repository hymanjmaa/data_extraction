# OpenRouter API配置
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-3.5-turbo

BAILIAN_API_KEY=your-bailian-api-key-here
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BAILIAN_MODEL=qwen3.6-plus

LLM_PROVIDER=qwen

# Flask配置
FLASK_ENV=development
SECRET_KEY=your-secret-key-here
DATABASE_URL=sqlite:///data_extraction.db

# 批处理配置
BATCH_SIZE=10
MAX_WORKERS=4
CONFIDENCE_THRESHOLD=0.7

WECHATY_SERVICE_URL=http://127.0.0.1:8788
WECHAT_INGEST_SECRET=please-set-a-random-string

PDF_OCR_ENABLED=0
PDF_OCR_PROVIDER=auto
OPENROUTER_OCR_MODEL=
